PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taoyuan_air
DB_USER=taoyuan_user
DB_PASSWORD=

# JWT
JWT_SECRET=

# 本地儲存路徑（相對於 backend/）
UPLOAD_DIR=uploads

# SFTP 目標 VM
# SFTP_HOST=
# SFTP_PORT=
# SFTP_USER=
# SFTP_PASSWORD=
