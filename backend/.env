PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taoyuan_air
DB_USER=taoyuan_user
DB_PASSWORD=taoyuan_pass

# JWT
JWT_SECRET=taoyuan-air-secret-2025

# 本地儲存路徑（相對於 backend/）
UPLOAD_DIR=uploads


# SFTP 目標 VM
SFTP_HOST=
SFTP_PORT=22
SFTP_USER=sftp_user
SFTP_PASSWORD=sftp_pass
# 若改用私鑰，請填入絕對路徑並移除 SFTP_PASSWORD
# SFTP_PRIVATE_KEY_PATH=/home/user/.ssh/id_rsa
# SFTP_PASSPHRASE=

# 遠端 VM 上的根目錄
SFTP_REMOTE_BASE=/data/taoyuan-air/uploads